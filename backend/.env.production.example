# =============================================================================
# Backend — PRODUCTION (resonaai.duckdns.org)
# Copy to .env.production and set ENV=production when running.
# Or set these as environment variables in systemd/Docker (no file needed).
# =============================================================================

ENV=production

# Database (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
REDIS_URL=redis://localhost:6379/0
INTERNAL_SECRET=your-internal-secret-min-32-chars

# LiveKit (use your LiveKit server)
# If backend runs in Docker and LiveKit is on the host: use host.docker.internal:7880 (Mac/Win) or host IP (Linux).
# If backend runs on host (systemd): use http://127.0.0.1:7880
LIVEKIT_URL=wss://resonaai.duckdns.org/livekit
LIVEKIT_API_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_SIP_URI=sip:your-key@YOUR_SERVER_IP:5060

# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# AI (Groq, Kokoro, Whisper)
GROQ_API_KEY=your-groq-api-key
KOKORO_TTS_URL=http://YOUR_TTS_HOST:8880/v1/audio/speech
KOKORO_TTS_VOICE=af_heart
KOKORO_TTS_MODEL=tts-1
WHISPER_STT_URL=http://YOUR_STT_HOST:8000/v1/audio/transcriptions

# App URLs — public URLs (no trailing slash)
API_BASE_URL=https://resonaai.duckdns.org
FRONTEND_URL=https://resonaai.duckdns.org
PUBLIC_HOST=resonaai.duckdns.org
CORS_ORIGINS=https://resonaai.duckdns.org

# Production: must be false
DEV_MODE=false
SECRET_KEY=your-secret-key-min-32-chars

SIP_SERVER_IP=127.0.0.1
