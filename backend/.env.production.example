# =============================================================================
# Resona AI — Production Environment
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://...

# Redis
REDIS_URL=redis://redis:6379/0

# LiveKit
LIVEKIT_URL=wss://your-domain.com/livekit
LIVEKIT_API_URL=http://172.31.x.x:7880
LIVEKIT_API_KEY=your_key
LIVEKIT_API_SECRET=your_secret
LIVEKIT_SIP_URI=sip:your_key@your_ip:5060

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_key

# LLM
GROQ_API_KEY=your_key
OPENAI_API_KEY=your_key

# Self-hosted TTS (Piper)
PIPER_TTS_URL=http://18.141.177.170:8880/v1/audio/speech
PIPER_TTS_VOICE=en_US-amy-medium
PIPER_TTS_MODEL=tts-1

# Self-hosted STT (Whisper.cpp OpenAI-compatible proxy, port 8002)
WHISPER_STT_URL=http://18.141.177.170:8002/v1/audio/transcriptions

# App
API_BASE_URL=https://your-domain.com/api
FRONTEND_URL=https://your-domain.com
PUBLIC_HOST=your-domain.com
CORS_ORIGINS=https://your-domain.com
ENV=production
DEV_MODE=false
SECRET_KEY=generate_with_openssl_rand_hex_32
INTERNAL_SECRET=generate_with_openssl_rand_hex_32
SIP_SERVER_IP=your_ip
