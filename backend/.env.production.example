# =============================================================================
# Resona AI — Production Environment
# =============================================================================

# Database
DATABASE_URL=postgresql+asyncpg://...

# Redis
REDIS_URL=redis://redis:6379/0

# LiveKit (worker connects to LIVEKIT_URL; browser uses LIVEKIT_PUBLIC_WS_URL when set)
LIVEKIT_URL=wss://resonaai.duckdns.org/livekit
LIVEKIT_PUBLIC_WS_URL=wss://resonaai.duckdns.org/livekit
LIVEKIT_API_URL=http://127.0.0.1:7880
LIVEKIT_API_KEY=your_key
LIVEKIT_API_SECRET=your_secret
LIVEKIT_SIP_URI=sip:your_key@18.141.140.150:5060

# Supabase (backend auth + frontend sign-in)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI API keys: store in DB (system_settings). Run scripts/seed_system_settings.sql.
# Optional env fallback: ELEVENLABS_API_KEY, OPENAI_API_KEY
# LLM: use Modal Llama-3.1-8B-Instant (OpenAI-compatible) or Groq via DB api-keys.
# MODAL_LLM_BASE_URL=https://your-workspace--your-app-serve.modal.run
# MODAL_API_KEY=optional-if-endpoint-requires-auth
# ElevenLabs defaults (no secrets):
ELEVENLABS_DEFAULT_VOICE_ID=bIHbv24MWmeRgasZH58o
ELEVENLABS_STT_MODEL=scribe_v2_realtime
ELEVENLABS_TTS_MODEL=eleven_turbo_v2_5
# TTS streaming latency: 0=default, 1-4=lower latency (2=balance, 4=max; agent worker)
ELEVENLABS_STREAMING_LATENCY=2

# App (when Nginx proxies API at /api, API_BASE_URL must end with /api)
API_BASE_URL=https://resonaai.duckdns.org/api
FRONTEND_URL=https://resonaai.duckdns.org
PUBLIC_HOST=resonaai.duckdns.org
CORS_ORIGINS=https://resonaai.duckdns.org
ENV=production
DEV_MODE=false
SECRET_KEY=generate_with_openssl_rand_hex_32
INTERNAL_SECRET=generate_with_openssl_rand_hex_32
SIP_SERVER_IP=your_ip
