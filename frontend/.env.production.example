# =============================================================================
# Frontend (Next.js) — PRODUCTION
# Copy to .env.production. Next.js loads it automatically for `next build` / `next start`.
# =============================================================================

# Backend API (no trailing slash)
NEXT_PUBLIC_API_URL=https://resonaai.duckdns.org

# LiveKit (must match backend LIVEKIT_URL)
NEXT_PUBLIC_LIVEKIT_URL=wss://resonaai.duckdns.org/livekit

# Twilio SIP origination (must match backend LIVEKIT_SIP_URI)
NEXT_PUBLIC_ORIGINATION_URI=sip:your-key@YOUR_SERVER_IP:5060

# Supabase (auth)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
