# =============================================================================
# Frontend (Next.js) — PRODUCTION
# Copy to .env.production. Next.js loads it for `next build` / `next start`.
# Root .env on server is used as .env.production when building Docker image.
# =============================================================================

# Backend API (no trailing slash). If Nginx proxies API at /api, use .../api
NEXT_PUBLIC_API_URL=https://resonaai.duckdns.org/api

# LiveKit (must match backend LIVEKIT_URL)
NEXT_PUBLIC_LIVEKIT_URL=wss://resonaai.duckdns.org/livekit

# Twilio SIP origination (must match backend LIVEKIT_SIP_URI)
NEXT_PUBLIC_ORIGINATION_URI=sip:your-key@18.141.140.150:5060

# Supabase (auth)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
